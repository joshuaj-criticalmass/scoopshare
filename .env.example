# Copy this to .env.local and fill in values from your Vercel/Upstash dashboard.
# Vercel Marketplace → Upstash Redis integration auto-populates these two:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set to your Vercel deployment URL (used to build the QR join link on /host)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
